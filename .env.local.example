# Firebase Client SDK
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin SDK (for API routes)
# Get these from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
FIREBASE_ADMIN_PROJECT_ID=your_project_id
FIREBASE_ADMIN_CLIENT_EMAIL=your_service_account_email@your_project.iam.gserviceaccount.com
# IMPORTANT: Copy the entire private key including -----BEGIN PRIVATE KEY----- and -----END PRIVATE KEY-----
# Replace newlines with \n (literal backslash-n, not actual newlines)
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG...\n-----END PRIVATE KEY-----\n"
FIREBASE_ADMIN_PRIVATE_KEY="your_private_key_here"

# === Vault / Brand Hub — Google Drive (optional, defaults to Firestore Base64) ===
# Set GOOGLE_DRIVE_ENABLED=true after completing setup in src/lib/drive-uploader.ts
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_DRIVE_PRIVATE_KEY=""
GOOGLE_DRIVE_IMPERSONATE_USER=nexayraarc@gmail.com
GOOGLE_DRIVE_VAULT_FOLDER_ID=
GOOGLE_DRIVE_BRAND_FOLDER_ID=

# === Vault — Gemini auto-extraction (optional, falls back to manual entry) ===
# Set GEMINI_ENABLED=true after getting an API key from https://aistudio.google.com/app/apikey
GEMINI_ENABLED=true
GEMINI_API_KEY=AIzaSyBIJHKKs3CiiwM1oJwP3vWcaBaa1A7hyW8
GEMINI_MODEL=gemini-2.0-flash